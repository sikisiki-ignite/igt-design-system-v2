{
  "name": "igt-design-system",
  "version": "0.1.0",
  "description": "IGT Design System — Back office React component library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "ai-guide",
    "bin",
    ".claude/skills"
  ],
  "bin": {
    "igt-init": "./bin/igt-init.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch",
    "showcase": "vite --config vite.config.showcase.ts",
    "build:showcase": "vite build --config vite.config.showcase.ts",
    "prototypes": "vite --config vite.config.prototypes.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^4.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }
}
